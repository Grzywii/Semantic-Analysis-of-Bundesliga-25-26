bundesliga:hasSquadMembership a owl:ObjectProperty ;
    rdfs:label "has squad membership"@en ;
    rdfs:domain bundesliga:Player ;
    rdfs:range bundesliga:SquadMembership ;
    owl:inverseOf bundesliga:membershipOfPlayer .

bundesliga:membershipOfPlayer a owl:ObjectProperty ;
    rdfs:label "membership of player"@en ;
    rdfs:domain bundesliga:SquadMembership ;
    rdfs:range bundesliga:Player ;
    owl:inverseOf bundesliga:hasSquadMembership .

