@prefix bundesliga: <http://example.org/bundesliga/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<http://example.org/bundesliga/ontology> a owl:Ontology ;
    rdfs:label "Bundesliga Ontology"@en ;
    rdfs:comment "Ontology for Bundesliga clubs, players, seasons, squad memberships, sporting performance, and financial records."@en .

bundesliga:age a owl:DatatypeProperty ;
    rdfs:label "age"@en ;
    rdfs:domain bundesliga:Player ;
    rdfs:range xsd:integer .

bundesliga:basedInCountry a owl:ObjectProperty ;
    rdfs:label "based in country"@en ;
    rdfs:domain bundesliga:Club ;
    rdfs:range bundesliga:Country .

bundesliga:birthDate a owl:DatatypeProperty ;
    rdfs:label "birth date"@en ;
    rdfs:domain bundesliga:Player ;
    rdfs:range xsd:date .

bundesliga:city a owl:DatatypeProperty ;
    rdfs:label "city"@en ;
    rdfs:domain bundesliga:Club ;
    rdfs:range xsd:string .

bundesliga:clubName a owl:DatatypeProperty ;
    rdfs:label "club name"@en ;
    rdfs:domain bundesliga:Club ;
    rdfs:range xsd:string .

bundesliga:continent a owl:DatatypeProperty ;
    rdfs:label "continent"@en ;
    rdfs:domain bundesliga:Country ;
    rdfs:range xsd:string .

bundesliga:countryName a owl:DatatypeProperty ;
    rdfs:label "country name"@en ;
    rdfs:domain bundesliga:Country ;
    rdfs:range xsd:string .

bundesliga:draws a owl:DatatypeProperty ;
    rdfs:label "draws"@en ;
    rdfs:domain bundesliga:ClubPerformance ;
    rdfs:range xsd:integer .

bundesliga:financialRecordInSeason a owl:ObjectProperty ;
    rdfs:label "financial record in season"@en ;
    rdfs:domain bundesliga:FinancialRecord ;
    rdfs:range bundesliga:Season .

bundesliga:goalDifference a owl:DatatypeProperty ;
    rdfs:label "goal difference"@en ;
    rdfs:domain bundesliga:ClubPerformance ;
    rdfs:range xsd:integer .

bundesliga:goalsAgainst a owl:DatatypeProperty ;
    rdfs:label "goals against"@en ;
    rdfs:domain bundesliga:ClubPerformance ;
    rdfs:range xsd:integer .

bundesliga:goalsFor a owl:DatatypeProperty ;
    rdfs:label "goals for"@en ;
    rdfs:domain bundesliga:ClubPerformance ;
    rdfs:range xsd:integer .

bundesliga:hasFinancialRecord a owl:ObjectProperty ;
    rdfs:label "has financial record"@en ;
    rdfs:domain bundesliga:Club ;
    rdfs:range bundesliga:FinancialRecord .

bundesliga:hasNationality a owl:ObjectProperty ;
    rdfs:label "has nationality"@en ;
    rdfs:domain bundesliga:Player ;
    rdfs:range bundesliga:Country .

bundesliga:hasPerformance a owl:ObjectProperty ;
    rdfs:label "has performance"@en ;
    rdfs:domain bundesliga:Club ;
    rdfs:range bundesliga:ClubPerformance .

bundesliga:hasPosition a owl:ObjectProperty ;
    rdfs:label "has position"@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( bundesliga:Player bundesliga:SquadMembership ) ] ;
    rdfs:range bundesliga:Position .

bundesliga:leagueName a owl:DatatypeProperty ;
    rdfs:label "league name"@en ;
    rdfs:domain bundesliga:League ;
    rdfs:range xsd:string .

bundesliga:leaguePosition a owl:DatatypeProperty ;
    rdfs:label "league position"@en ;
    rdfs:domain bundesliga:ClubPerformance ;
    rdfs:range xsd:integer .

bundesliga:losses a owl:DatatypeProperty ;
    rdfs:label "losses"@en ;
    rdfs:domain bundesliga:ClubPerformance ;
    rdfs:range xsd:integer .

bundesliga:marketValueEUR a owl:DatatypeProperty ;
    rdfs:label "market value EUR"@en ;
    rdfs:domain bundesliga:SquadMembership ;
    rdfs:range xsd:decimal .

bundesliga:matchesPlayed a owl:DatatypeProperty ;
    rdfs:label "matches played"@en ;
    rdfs:domain bundesliga:ClubPerformance ;
    rdfs:range xsd:integer .

bundesliga:membershipForClub a owl:ObjectProperty ;
    rdfs:label "membership for club"@en ;
    rdfs:domain bundesliga:SquadMembership ;
    rdfs:range bundesliga:Club .

bundesliga:membershipInSeason a owl:ObjectProperty ;
    rdfs:label "membership in season"@en ;
    rdfs:domain bundesliga:SquadMembership ;
    rdfs:range bundesliga:Season .

bundesliga:netTransferSpendingEUR a owl:DatatypeProperty ;
    rdfs:label "net transfer spending EUR"@en ;
    rdfs:domain bundesliga:FinancialRecord ;
    rdfs:range xsd:decimal .

bundesliga:performanceInSeason a owl:ObjectProperty ;
    rdfs:label "performance in season"@en ;
    rdfs:domain bundesliga:ClubPerformance ;
    rdfs:range bundesliga:Season .

bundesliga:performanceScore a owl:DatatypeProperty ;
    rdfs:label "performance score"@en ;
    rdfs:domain bundesliga:ClubPerformance ;
    rdfs:range xsd:decimal .

bundesliga:playerName a owl:DatatypeProperty ;
    rdfs:label "player name"@en ;
    rdfs:domain bundesliga:Player ;
    rdfs:range xsd:string .

bundesliga:playsInLeague a owl:ObjectProperty ;
    rdfs:label "plays in league"@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( bundesliga:Club bundesliga:ClubPerformance ) ] ;
    rdfs:range bundesliga:League .

bundesliga:points a owl:DatatypeProperty ;
    rdfs:label "points"@en ;
    rdfs:domain bundesliga:ClubPerformance ;
    rdfs:range xsd:integer .

bundesliga:positionGroup a owl:DatatypeProperty ;
    rdfs:label "position group"@en ;
    rdfs:domain bundesliga:Position ;
    rdfs:range xsd:string .

bundesliga:positionName a owl:DatatypeProperty ;
    rdfs:label "position name"@en ;
    rdfs:domain bundesliga:Position ;
    rdfs:range xsd:string .

bundesliga:seasonLabel a owl:DatatypeProperty ;
    rdfs:label "season label"@en ;
    rdfs:domain bundesliga:Season ;
    rdfs:range xsd:string .

bundesliga:shortName a owl:DatatypeProperty ;
    rdfs:label "short name"@en ;
    rdfs:domain bundesliga:Club ;
    rdfs:range xsd:string .

bundesliga:squadMarketValueEUR a owl:DatatypeProperty ;
    rdfs:label "squad market value EUR"@en ;
    rdfs:domain bundesliga:FinancialRecord ;
    rdfs:range xsd:decimal .

bundesliga:stadium a owl:DatatypeProperty ;
    rdfs:label "stadium"@en ;
    rdfs:domain bundesliga:Club ;
    rdfs:range xsd:string .

bundesliga:transferIncomeEUR a owl:DatatypeProperty ;
    rdfs:label "transfer income EUR"@en ;
    rdfs:domain bundesliga:FinancialRecord ;
    rdfs:range xsd:decimal .

bundesliga:transferSpendingEUR a owl:DatatypeProperty ;
    rdfs:label "transfer spending EUR"@en ;
    rdfs:domain bundesliga:FinancialRecord ;
    rdfs:range xsd:decimal .

bundesliga:wins a owl:DatatypeProperty ;
    rdfs:label "wins"@en ;
    rdfs:domain bundesliga:ClubPerformance ;
    rdfs:range xsd:integer .

